      background: var(--accent-dim) !important;
    }
    .fab-add {
      background: var(--accent) !important;
      box-shadow: 0 6px 20px rgba(79,124,255,.35) !important;
    }
    
    /* ===== INPUTS ===== */
    .g-input:focus {
      border-color: var(--border-focus) !important;
      box-shadow: 0 0 0 3px rgba(211,107,53,.15) !important;
    }
    
    /* ===== HEADER GUIDE CARD ===== */
    .header-guide-card {
      border-color: rgba(79,124,255,.18) !important;
    }
    .header-guide-ico {
      color: var(--accent) !important;
      border-color: rgba(79,124,255,.18) !important;
    }
    .header-guide-eye {
      background: var(--accent-dim) !important;
      color: var(--accent) !important;
      border-color: rgba(79,124,255,.22) !important;
    }
    .staff-daily-preview-wrap,
    .staff-daily-note-preview,
    .staff-daily-public-text {
      background: var(--accent-dim) !important;
      border-color: rgba(79,124,255,.22) !important;
    }
    .staff-daily-preview-title { color: var(--accent) !important; } /* Keep accent color */
    
    /* ===== AMOUNT DISPLAY ===== */
    .amount-display { color: var(--accent) !important; }
    
    /* ===== HEADER GUIDE NOTE ===== */
    .header-guide-note-preview {
      background: var(--green-dim) !important;
      border-color: rgba(46,138,94,.24) !important;
    }
    .header-guide-card.is-hidden {
      background: var(--green-dim) !important;
      border-color: rgba(46,138,94,.24) !important;
    }
    
    /* ===== LOADING ===== */
    #loading { background: rgba(44,36,32,.7) !important; }
    .loader-ring { border-top-color: var(--accent) !important; } /* Keep accent color */
    
    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg3); }
    ::-webkit-scrollbar-thumb { background: rgba(90,70,50,.3); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent); }
    
    /* ===== LOGIN BRAND ===== */
    .login-brand {
      background: var(--accent-dim) !important; /* Keep accent color */
      border-color: rgba(79,124,255,.22) !important;
    }
    
    /* ===== STAT MINI colored accent ===== */
    .stat-mini-lbl { color: var(--text-ghost) !important; }
    
    /* ===== STAFF AVATAR ===== */
    .staff-daily-avatar { background: var(--accent) !important; }
    
