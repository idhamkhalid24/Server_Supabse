      color: var(--accent) !important;
      box-shadow: inset 0 0 0 1px rgba(211,107,53,.2) !important;
    }
    
    /* ===== MODAL ===== */
    .modal-sheet {
      background: var(--bg2) !important;
      border-color: rgba(79,124,255,.14) !important;
      box-shadow: 0 20px 60px rgba(60,40,20,.18) !important;
    }
