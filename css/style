    /* ===== ROCKY HIJAB - WARM SAND THEME ===== */
    /* Background gradient untuk body */
    html, body, #app {
      background: var(--bg) !important;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: 
        radial-gradient(ellipse at 15% 0%, rgba(37,99,235,.03) 0%, transparent 50%),
        radial-gradient(ellipse at 85% 100%, rgba(148,163,184,.03) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }
    
    /* ===== CARDS - subtle warm shadow, soft border ===== */
    .card, .stat-mini, .trx-card, .setting-row {
      background: var(--bg2) !important;
