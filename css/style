      box-shadow: 0 1.5px 4px rgba(234, 88, 12, 0.18) !important;
    }
    .badge-green {
      background: rgba(22, 101, 52, 0.12) !important; /* Darker Green for Cash */
      color: #166534 !important;
      border: 1.5px solid rgba(22, 101, 52, 0.32) !important;
      box-shadow: 0 1.5px 4px rgba(22, 101, 52, 0.14) !important;
    }
    .user-chip {
      background: var(--bg3) !important;
      border-color: var(--border) !important;
      box-shadow: 0 1.5px 4px rgba(0, 0, 0, 0.06) !important;
    }
    
    /* ===== BUTTONS ===== */
    .btn-primary { background: var(--accent) !important; color: #fff !important; }
    .btn-primary:hover:not(:disabled) { background: #c05e28 !important; }
    .btn-success { background: var(--green) !important; color: #fff !important; }
    .sync-btn {
      background: var(--accent-dim) !important;
      border-color: rgba(79,124,255,.22) !important; /* Keep blue for sync */
