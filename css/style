      background: rgba(90,70,50,.08) !important;
      border-color: rgba(79,124,255,.12) !important;
    }
    .tab-btn.active {
      background: var(--accent) !important;
      color: #fff !important;
    }
    
    /* ===== CHIPS & BADGES ===== */
    .loc-in, .status-ok {
      background: var(--green-dim) !important;
      color: var(--green) !important;
      border-color: rgba(46,138,94,.2) !important;
    }
    .loc-out, .status-warn {
      background: var(--red-dim) !important;
      color: var(--red) !important;
      border-color: rgba(201,64,64,.2) !important;
    }
    .badge-blue {
